default: &default
  adapter: postgresql
  encoding: unicode
  pool: <%= ENV.fetch("RAILS_MAX_THREADS") { 5 } %>

development:
  <<: *default
  database: sandwich_development

test:
  <<: *default
  url: postgres://test:test@localhost/sandwich_test

production:
  <<: *default
  url: <%= ENV.fetch("DATABASE_URL") %>

